#ifndef _BAT_DEQUE
#define _BAT_DEQUE

#include <cstddef>
#include <type_traits>
#include <utility>
#include <new>
#include <initializer_list>
#include <iterator>
#include <memory>

namespace std {

template<class T, class Allocator = allocator<T>>
class deque {
public:
    using value_type = T;
    using allocator_type = Allocator;
    using size_type = size_t;
    using difference_type = ptrdiff_t;
    using reference = T&;
    using const_reference = const T&;
    using pointer = T*;
    using const_pointer = const T*;
    using iterator = T*;
    using const_iterator = const T*;
    using reverse_iterator = std::reverse_iterator<iterator>;
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;

private:
    T* data_; size_type sz_, cap_;

    void grow() {
        size_type nc = cap_ == 0 ? 8 : cap_ * 2;
        T* nd = static_cast<T*>(::operator new(nc * sizeof(T)));
        for (size_type i = 0; i < sz_; i++) { ::new(&nd[i]) T(static_cast<T&&>(data_[i])); data_[i].~T(); }
        if (data_) ::operator delete(data_);
        data_ = nd; cap_ = nc;
    }

public:
    deque() : data_(nullptr), sz_(0), cap_(0) {}
    explicit deque(const Allocator&) : data_(nullptr), sz_(0), cap_(0) {}
    explicit deque(size_type n, const T& v = T(), const Allocator& = Allocator()) : data_(nullptr), sz_(0), cap_(0) { for(size_type i=0;i<n;i++) push_back(v); }
    deque(const deque& o) : data_(nullptr), sz_(0), cap_(0) { for(size_type i=0;i<o.sz_;i++) push_back(o.data_[i]); }
    deque(deque&& o) noexcept : data_(o.data_), sz_(o.sz_), cap_(o.cap_) { o.data_=nullptr; o.sz_=0; o.cap_=0; }
    deque(initializer_list<T> il) : data_(nullptr), sz_(0), cap_(0) { for(auto& v:il) push_back(v); }
    template<class It, class=decltype(*declval<It>())>
    deque(It f, It l, const Allocator& = Allocator()) : data_(nullptr), sz_(0), cap_(0) { for(;f!=l;++f) push_back(*f); }
    deque& operator=(const deque& o) { if(this!=&o){clear();for(size_type i=0;i<o.sz_;i++)push_back(o.data_[i]);} return *this; }
    deque& operator=(deque&& o) noexcept { if(this!=&o){clear();if(data_)::operator delete(data_);data_=o.data_;sz_=o.sz_;cap_=o.cap_;o.data_=nullptr;o.sz_=0;o.cap_=0;} return *this; }
    ~deque() { clear(); if(data_) ::operator delete(data_); }

    void push_back(const T& v) { if(sz_>=cap_)grow(); ::new(&data_[sz_])T(v); sz_++; }
    void push_back(T&& v) { if(sz_>=cap_)grow(); ::new(&data_[sz_])T(static_cast<T&&>(v)); sz_++; }
    template<class...A> T& emplace_back(A&&...a) { if(sz_>=cap_)grow(); ::new(&data_[sz_])T(static_cast<A&&>(a)...); return data_[sz_++]; }
    void push_front(const T& v) { if(sz_>=cap_)grow(); for(size_type i=sz_;i>0;i--){::new(&data_[i])T(static_cast<T&&>(data_[i-1]));data_[i-1].~T();} ::new(&data_[0])T(v); sz_++; }
    void pop_back() { if(sz_>0){data_[--sz_].~T();} }
    void pop_front() { if(sz_>0){data_[0].~T();for(size_type i=0;i<sz_-1;i++){::new(&data_[i])T(static_cast<T&&>(data_[i+1]));data_[i+1].~T();}sz_--;} }

    T& operator[](size_type i) { return data_[i]; }
    const T& operator[](size_type i) const { return data_[i]; }
    T& at(size_type i) { return data_[i]; }
    T& front() { return data_[0]; }
    const T& front() const { return data_[0]; }
    T& back() { return data_[sz_-1]; }
    const T& back() const { return data_[sz_-1]; }

    size_type size() const { return sz_; }
    bool empty() const { return sz_==0; }
    void clear() { for(size_type i=0;i<sz_;i++)data_[i].~T(); sz_=0; }
    void resize(size_type n, const T& v=T()) { while(sz_>n)pop_back(); while(sz_<n)push_back(v); }

    iterator begin() { return data_; }
    iterator end() { return data_+sz_; }
    const_iterator begin() const { return data_; }
    const_iterator end() const { return data_+sz_; }
    const_iterator cbegin() const { return data_; }
    const_iterator cend() const { return data_+sz_; }
    reverse_iterator rbegin() { return reverse_iterator(end()); }
    reverse_iterator rend() { return reverse_iterator(begin()); }
    const_reverse_iterator rbegin() const { return const_reverse_iterator(end()); }
    const_reverse_iterator rend() const { return const_reverse_iterator(begin()); }

    iterator erase(const_iterator pos) {
        size_type i=pos-data_; data_[i].~T();
        for(size_type j=i;j<sz_-1;j++){::new(&data_[j])T(static_cast<T&&>(data_[j+1]));data_[j+1].~T();}
        sz_--; return data_+i;
    }
    iterator insert(const_iterator pos, const T& v) {
        size_type i=pos-data_; if(sz_>=cap_)grow();
        for(size_type j=sz_;j>i;j--){::new(&data_[j])T(static_cast<T&&>(data_[j-1]));data_[j-1].~T();}
        ::new(&data_[i])T(v); sz_++; return data_+i;
    }
    void swap(deque& o) noexcept { auto t=data_;data_=o.data_;o.data_=t; auto s=sz_;sz_=o.sz_;o.sz_=s; auto c=cap_;cap_=o.cap_;o.cap_=c; }
    allocator_type get_allocator() const { return Allocator(); }
};

} // namespace std
#endif
