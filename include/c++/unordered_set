#ifndef _BAT_UNORDERED_SET
#define _BAT_UNORDERED_SET

#include <cstddef>
#include <utility>
#include <memory>
#include <functional>
#include <initializer_list>

extern "C" void abort();

namespace std {

template<class Key,
         class Hash = hash<Key>,
         class KeyEqual = equal_to<Key>,
         class Allocator = allocator<Key>>
class unordered_set {
public:
    using key_type   = Key;
    using value_type = Key;
    using hasher     = Hash;
    using key_equal  = KeyEqual;
    using size_type       = size_t;
    using difference_type = ptrdiff_t;
    using reference       = const Key&;
    using const_reference = const Key&;

private:
    static constexpr size_type MAX_ENTRIES = 128;

    struct Entry {
        Key  key;
        bool occupied;
    };

    Entry    entries_[MAX_ENTRIES];
    size_type size_;
    Hash     hash_;
    KeyEqual eq_;

    size_type find_slot(const Key& k) const {
        for (size_type i = 0; i < MAX_ENTRIES; ++i) {
            if (entries_[i].occupied && eq_(entries_[i].key, k))
                return i;
        }
        return MAX_ENTRIES;
    }

public:
    struct iterator {
        const Entry* ptr_;
        const Entry* end_;

        using value_type = const Key;
        using difference_type = ptrdiff_t;
        using pointer = const Key*;
        using reference = const Key&;

        reference operator*() const { return ptr_->key; }
        pointer operator->() const { return &ptr_->key; }
        iterator& operator++() {
            ++ptr_;
            while (ptr_ < end_ && !ptr_->occupied) ++ptr_;
            return *this;
        }
        iterator operator++(int) { auto tmp = *this; ++(*this); return tmp; }
        bool operator==(const iterator& o) const { return ptr_ == o.ptr_; }
        bool operator!=(const iterator& o) const { return ptr_ != o.ptr_; }
    };

    using const_iterator = iterator;

    unordered_set() : size_(0) {
        for (size_type i = 0; i < MAX_ENTRIES; ++i)
            entries_[i].occupied = false;
    }
    explicit unordered_set(size_type, const Hash& = Hash(), const KeyEqual& = KeyEqual(),
                           const Allocator& = Allocator()) : unordered_set() {}
    explicit unordered_set(const Allocator&) : unordered_set() {}

    unordered_set(std::initializer_list<Key> init) : unordered_set() {
        for (auto& k : init) insert(k);
    }

    template<class InputIt>
    unordered_set(InputIt first, InputIt last) : unordered_set() {
        while (first != last) { insert(*first); ++first; }
    }

    unordered_set(const unordered_set&) = default;
    unordered_set& operator=(const unordered_set&) = default;
    unordered_set(unordered_set&&) = default;
    unordered_set& operator=(unordered_set&&) = default;
    ~unordered_set() = default;

    pair<iterator, bool> insert(const Key& k) {
        size_type slot = find_slot(k);
        if (slot < MAX_ENTRIES)
            return {iterator{&entries_[slot], &entries_[MAX_ENTRIES]}, false};
        for (size_type i = 0; i < MAX_ENTRIES; ++i) {
            if (!entries_[i].occupied) {
                entries_[i].key = k;
                entries_[i].occupied = true;
                ++size_;
                return {iterator{&entries_[i], &entries_[MAX_ENTRIES]}, true};
            }
        }
        abort();
        return {end(), false};
    }

    template<class... Args>
    pair<iterator, bool> emplace(Args&&... args) {
        Key k(static_cast<Args&&>(args)...);
        return insert(k);
    }

    iterator find(const Key& k) const {
        size_type slot = find_slot(k);
        if (slot < MAX_ENTRIES)
            return iterator{&entries_[slot], &entries_[MAX_ENTRIES]};
        return end();
    }

    size_type count(const Key& k) const {
        return find_slot(k) < MAX_ENTRIES ? 1 : 0;
    }

    bool contains(const Key& k) const {
        return find_slot(k) < MAX_ENTRIES;
    }

    size_type erase(const Key& k) {
        size_type slot = find_slot(k);
        if (slot >= MAX_ENTRIES) return 0;
        entries_[slot].occupied = false;
        --size_;
        return 1;
    }

    void clear() {
        for (size_type i = 0; i < MAX_ENTRIES; ++i)
            entries_[i].occupied = false;
        size_ = 0;
    }

    size_type size() const noexcept { return size_; }
    bool empty() const noexcept { return size_ == 0; }
    size_type max_size() const noexcept { return MAX_ENTRIES; }

    iterator begin() const noexcept {
        const Entry* p = entries_;
        while (p < entries_ + MAX_ENTRIES && !p->occupied) ++p;
        return iterator{p, entries_ + MAX_ENTRIES};
    }
    iterator end() const noexcept {
        return iterator{entries_ + MAX_ENTRIES, entries_ + MAX_ENTRIES};
    }
    const_iterator cbegin() const noexcept { return begin(); }
    const_iterator cend() const noexcept { return end(); }

    void reserve(size_type) {} // no-op
    size_type bucket_count() const noexcept { return 64; }
};

} // namespace std

#endif
