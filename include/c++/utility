// addressof (also in <memory> but needed early)
#ifndef _BAT_ADDRESSOF_DEFINED
#define _BAT_ADDRESSOF_DEFINED
template<class T>
constexpr T* addressof(T& ref) noexcept { return __builtin_addressof(ref); }
#endif

// move
template<class T>
constexpr remove_reference_t<T>&& move(T&& t) noexcept {
    return static_cast<remove_reference_t<T>&&>(t);
}

// forward
template<class T>
constexpr T&& forward(remove_reference_t<T>& t) noexcept {
    return static_cast<T&&>(t);
}
template<class T>
constexpr T&& forward(remove_reference_t<T>&& t) noexcept {
    return static_cast<T&&>(t);
}

// swap
template<class T>
inline void swap(T& a, T& b) noexcept {
    T tmp = std::move(a);
    a = std::move(b);
    b = std::move(tmp);
}

template<class T, size_t N>
inline void swap(T (&a)[N], T (&b)[N]) noexcept {
    for (size_t i = 0; i < N; ++i)
        swap(a[i], b[i]);
}

// exchange
template<class T, class U = T>
inline T exchange(T& obj, U&& new_value) {
    T old_value = std::move(obj);
    obj = std::forward<U>(new_value);
    return old_value;
}

// Forward declarations for pair
template<class... Ts> class tuple;
struct piecewise_construct_t { explicit constexpr piecewise_construct_t() = default; };
inline constexpr piecewise_construct_t piecewise_construct{};

// pair
template<class T1, class T2>
struct pair {
    using first_type  = T1;
    using second_type = T2;

    T1 first;
    T2 second;

    constexpr pair() : first(), second() {}
    constexpr pair(const T1& a, const T2& b) : first(a), second(b) {}

    template<class U1, class U2>
    constexpr pair(U1&& a, U2&& b) : first(std::forward<U1>(a)), second(std::forward<U2>(b)) {}

    template<class U1, class U2>
    constexpr pair(const pair<U1, U2>& p) : first(p.first), second(p.second) {}

    // piecewise construct support is in <tuple> (after tuple is defined)

    pair(const pair&) = default;
    pair(pair&&) = default;
    pair& operator=(const pair&) = default;
    pair& operator=(pair&&) = default;

    void swap(pair& o) {
        std::swap(first, o.first);
        std::swap(second, o.second);
    }
};

template<class T1, class T2>
constexpr pair<decay_t<T1>, decay_t<T2>> make_pair(T1&& a, T2&& b) {
    return pair<decay_t<T1>, decay_t<T2>>(std::forward<T1>(a), std::forward<T2>(b));
}

// tuple_size / tuple_element for pair (structured bindings support)
// Primary templates are defined in <tuple>; if not included yet, declare them here
#ifndef _BAT_TUPLE_SIZE_DECLARED
#define _BAT_TUPLE_SIZE_DECLARED
template<class T> struct tuple_size;
template<size_t I, class T> struct tuple_element;
#endif
template<class T1, class T2> struct tuple_size<pair<T1,T2>> : integral_constant<size_t, 2> {};
template<class T1, class T2> struct tuple_element<0, pair<T1,T2>> { using type = T1; };
template<class T1, class T2> struct tuple_element<1, pair<T1,T2>> { using type = T2; };
// const pair
template<size_t I, class T> struct tuple_element<I, const T> {
    using type = typename add_const<typename tuple_element<I, T>::type>::type;
};
template<size_t I, class T1, class T2>
constexpr auto& get(pair<T1,T2>& p) noexcept {
    if constexpr (I == 0) return p.first;
    else return p.second;
}
template<size_t I, class T1, class T2>
constexpr const auto& get(const pair<T1,T2>& p) noexcept {
    if constexpr (I == 0) return p.first;
    else return p.second;
}
template<size_t I, class T1, class T2>
constexpr auto&& get(pair<T1,T2>&& p) noexcept {
    if constexpr (I == 0) return std::move(p.first);
    else return std::move(p.second);
}
template<size_t I, class T1, class T2>
constexpr const auto&& get(const pair<T1,T2>&& p) noexcept {
    if constexpr (I == 0) return std::move(p.first);
    else return std::move(p.second);
}

template<class T1, class T2>
constexpr bool operator==(const pair<T1,T2>& a, const pair<T1,T2>& b) {
    return a.first == b.first && a.second == b.second;
}
template<class T1, class T2>
constexpr bool operator!=(const pair<T1,T2>& a, const pair<T1,T2>& b) {
    return !(a == b);
}
template<class T1, class T2>
constexpr bool operator<(const pair<T1,T2>& a, const pair<T1,T2>& b) {
    return a.first < b.first || (!(b.first < a.first) && a.second < b.second);
}

// integer_sequence
template<class T, T... Ints>
struct integer_sequence {
    using value_type = T;
    static constexpr size_t size() noexcept { return sizeof...(Ints); }
};

template<size_t... Ints>
using index_sequence = integer_sequence<size_t, Ints...>;

namespace detail {
    template<class T, int N, T... Ints>
    struct make_seq_helper {
        using type = typename make_seq_helper<T, N-1, static_cast<T>(N-1), Ints...>::type;
    };
    template<class T, T... Ints>
    struct make_seq_helper<T, 0, Ints...> {
        using type = integer_sequence<T, Ints...>;
    };
}

template<class T, T N>
using make_integer_sequence = typename detail::make_seq_helper<T, N>::type;
template<size_t N>
using make_index_sequence = make_integer_sequence<size_t, N>;
template<class... T>
using index_sequence_for = make_index_sequence<sizeof...(T)>;

