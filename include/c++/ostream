#ifndef _BAT_OSTREAM
#define _BAT_OSTREAM

#include <cstdio>
#include <cstddef>
#include <memory>

namespace std {

template<class CharT> struct char_traits;
template<class CharT, class Traits> class basic_ostream;

using streamsize = long long;

template<class CharT, class Traits>
class basic_ostream {
public:
    basic_ostream() {}
    virtual ~basic_ostream() {}

    basic_ostream& operator<<(const char* s) { if (s) printf("%s", s); return *this; }
    basic_ostream& operator<<(char c) { printf("%c", c); return *this; }
    basic_ostream& operator<<(int v) { printf("%d", v); return *this; }
    basic_ostream& operator<<(unsigned int v) { printf("%u", v); return *this; }
    basic_ostream& operator<<(long v) { printf("%ld", v); return *this; }
    basic_ostream& operator<<(unsigned long v) { printf("%lu", v); return *this; }
    basic_ostream& operator<<(long long v) { printf("%lld", v); return *this; }
    basic_ostream& operator<<(unsigned long long v) { printf("%llu", v); return *this; }
    basic_ostream& operator<<(double v) { printf("%f", v); return *this; }
    basic_ostream& operator<<(float v) { printf("%f", (double)v); return *this; }
    basic_ostream& operator<<(const void* p) { printf("%p", p); return *this; }
    basic_ostream& operator<<(bool b) { printf("%s", b ? "true" : "false"); return *this; }
    basic_ostream& operator<<(basic_ostream& (*manip)(basic_ostream&)) { return manip(*this); }

    basic_ostream& write(const char* s, streamsize n) {
        for (streamsize i = 0; i < n; i++) printf("%c", s[i]);
        return *this;
    }
    basic_ostream& put(char c) { printf("%c", c); return *this; }
    basic_ostream& flush() { return *this; }

    explicit operator bool() const { return true; }
    bool good() const { return true; }
    bool fail() const { return false; }

    // Formatting state (for V8's bytecode decoder)
    using fmtflags = unsigned int;
    static constexpr fmtflags hex = 1;
    static constexpr fmtflags dec = 0;
    fmtflags flags_ = 0;
    char fill_ = ' ';

    fmtflags flags() const { return flags_; }
    fmtflags flags(fmtflags f) { auto old = flags_; flags_ = f; return old; }
    char fill() const { return fill_; }
    char fill(char c) { auto old = fill_; fill_ = c; return old; }
    void copyfmt(const basic_ostream&) {}
    template<class C2, class T2> void copyfmt(const basic_ios<C2,T2>&) {}
    int width() const { return 0; }
    int width(int) { return 0; }
};

// basic_ios — minimal standalone stub for format save/restore
template<class CharT, class Traits>
class basic_ios {
public:
    using fmtflags = unsigned int;
    static constexpr fmtflags hex = 1;
    static constexpr fmtflags dec = 0;

    basic_ios() {}
    explicit basic_ios(void*) {}
    void copyfmt(const basic_ios&) {}
    fmtflags flags() const { return 0; }
    fmtflags flags(fmtflags) { return 0; }
    char fill() const { return ' '; }
    char fill(char) { return ' '; }
    bool good() const { return true; }
    bool fail() const { return false; }
    explicit operator bool() const { return true; }
};

using ios = basic_ios<char, char_traits<char>>;

using ostream = basic_ostream<char, char_traits<char>>;

template<class CharT, class Traits>
basic_ostream<CharT, Traits>& endl(basic_ostream<CharT, Traits>& os) { os.put('\n'); return os; }

// I/O manipulators
inline ostream& hex(ostream& os) { return os; }
inline ostream& dec(ostream& os) { return os; }
inline ostream& oct(ostream& os) { return os; }
inline ostream& left(ostream& os) { return os; }
inline ostream& right(ostream& os) { return os; }
inline ostream& fixed(ostream& os) { return os; }
inline ostream& scientific(ostream& os) { return os; }

inline ostream cout;
inline ostream cerr;
inline ostream clog;

// String support — defined after string is included
// This is a non-member operator so it doesn't need the full string type here
} // namespace std

// Include string to get operator<< for it
#include <string>

namespace std {
inline basic_ostream<char, char_traits<char>>& operator<<(
    basic_ostream<char, char_traits<char>>& os, const string& s) {
    os.write(s.c_str(), s.size());
    return os;
}
} // namespace std (reopened)

#endif
