#ifndef _BAT_THREAD
#define _BAT_THREAD

#include <cstddef>
#include <cstdint>

// Stub thread header — no actual threading support
// Just provides types that code can reference

namespace std {

class thread {
public:
    class id {
        uint64_t id_;
    public:
        constexpr id() noexcept : id_(0) {}
        explicit constexpr id(uint64_t i) noexcept : id_(i) {}

        friend constexpr bool operator==(id a, id b) noexcept { return a.id_ == b.id_; }
        friend constexpr bool operator!=(id a, id b) noexcept { return a.id_ != b.id_; }
        friend constexpr bool operator<(id a, id b) noexcept { return a.id_ < b.id_; }
        friend constexpr bool operator<=(id a, id b) noexcept { return a.id_ <= b.id_; }
        friend constexpr bool operator>(id a, id b) noexcept { return a.id_ > b.id_; }
        friend constexpr bool operator>=(id a, id b) noexcept { return a.id_ >= b.id_; }
    };

    thread() noexcept = default;

    // No actual thread creation — this is a stub
    // template<class F, class... Args> explicit thread(F&&, Args&&...) { abort(); }

    thread(const thread&) = delete;
    thread(thread&&) noexcept = default;

    ~thread() = default;

    thread& operator=(const thread&) = delete;
    thread& operator=(thread&&) noexcept = default;

    bool joinable() const noexcept { return false; }
    void join() {}
    void detach() {}

    id get_id() const noexcept { return id{}; }

    static unsigned int hardware_concurrency() noexcept { return 1; }

    void swap(thread& o) noexcept { (void)o; }
};

namespace this_thread {
    inline thread::id get_id() noexcept { return thread::id{1}; }

    inline void yield() noexcept {}

    // sleep_for / sleep_until would need chrono — just declare as no-ops
    template<class Rep, class Period>
    inline void sleep_for(const Rep&) noexcept {}

    template<class Clock, class Duration>
    inline void sleep_until(const Clock&) noexcept {}
}

} // namespace std

#endif
