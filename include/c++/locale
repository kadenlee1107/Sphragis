#ifndef _BAT_LOCALE
#define _BAT_LOCALE

#include <cstddef>

namespace std {

// Minimal locale stub — just enough for headers that reference it
class locale {
public:
    class id {
    public:
        id() {}
        id(const id&) = delete;
        id& operator=(const id&) = delete;
    };

    class facet {
    public:
        explicit facet(size_t refs = 0) { (void)refs; }
        virtual ~facet() {}
        facet(const facet&) = delete;
        facet& operator=(const facet&) = delete;
    };

    // category
    using category = int;
    static constexpr category none     = 0;
    static constexpr category collate  = 1 << 0;
    static constexpr category ctype    = 1 << 1;
    static constexpr category monetary = 1 << 2;
    static constexpr category numeric  = 1 << 3;
    static constexpr category time     = 1 << 4;
    static constexpr category messages = 1 << 5;
    static constexpr category all      = collate | ctype | monetary | numeric | time | messages;

    locale() noexcept {}
    locale(const locale&) noexcept {}
    locale(const char*) {}
    ~locale() {}

    locale& operator=(const locale&) noexcept { return *this; }

    bool operator==(const locale&) const { return true; }
    bool operator!=(const locale& o) const { return !(*this == o); }

    static const locale& classic() {
        static locale c;
        return c;
    }
};

// ctype_base
struct ctype_base {
    using mask = unsigned short;
    static constexpr mask space  = 1 << 0;
    static constexpr mask print  = 1 << 1;
    static constexpr mask cntrl  = 1 << 2;
    static constexpr mask upper  = 1 << 3;
    static constexpr mask lower  = 1 << 4;
    static constexpr mask alpha  = 1 << 5;
    static constexpr mask digit  = 1 << 6;
    static constexpr mask punct  = 1 << 7;
    static constexpr mask xdigit = 1 << 8;
    static constexpr mask alnum  = alpha | digit;
    static constexpr mask graph  = alnum | punct;
    static constexpr mask blank  = 1 << 9;
};

} // namespace std

#endif
