#ifndef _BAT_MAP
#define _BAT_MAP

#include <cstddef>
#include <utility>
#include <functional>
#include <memory>
#include <initializer_list>
#include <iterator>
#include <new>

namespace std {

template<class Key, class T, class Compare = less<Key>,
         class Allocator = allocator<pair<const Key, T>>>
class map {
public:
    using key_type = Key;
    using mapped_type = T;
    using value_type = pair<const Key, T>;
    using size_type = size_t;
    using difference_type = ptrdiff_t;
    using key_compare = Compare;
    using allocator_type = Allocator;
    using reference = value_type&;
    using const_reference = const value_type&;

private:
    struct Node {
        value_type data;
        template<class... Args>
        Node(Args&&... args) : data(static_cast<Args&&>(args)...) {}
    };

    Node** arr_;
    size_type sz_;
    size_type cap_;
    Compare comp_;

    void grow() {
        size_type nc = cap_ == 0 ? 8 : cap_ * 2;
        Node** na = static_cast<Node**>(::operator new(nc * sizeof(Node*)));
        for (size_type i = 0; i < sz_; i++) na[i] = arr_[i];
        if (arr_) ::operator delete(arr_);
        arr_ = na;
        cap_ = nc;
    }

    size_type fpos(const Key& k) const {
        for (size_type i = 0; i < sz_; i++)
            if (!comp_(arr_[i]->data.first, k) && !comp_(k, arr_[i]->data.first)) return i;
        return sz_;
    }

    size_type ipos(const Key& k) const {
        size_type i = 0;
        while (i < sz_ && comp_(arr_[i]->data.first, k)) i++;
        return i;
    }

    Node* make_node(const value_type& v) {
        Node* n = static_cast<Node*>(::operator new(sizeof(Node)));
        ::new(n) Node(v);
        return n;
    }

    void free_node(Node* n) { n->~Node(); ::operator delete(n); }

    void shift_right(size_type pos) {
        for (size_type i = sz_; i > pos; i--) arr_[i] = arr_[i-1];
    }

public:
    struct iterator {
        Node** p;
        using value_type = pair<const Key, T>;
        using difference_type = ptrdiff_t;
        using pointer = value_type*;
        using reference = value_type&;
        using iterator_category = bidirectional_iterator_tag;
        iterator(Node** x = nullptr) : p(x) {}
        reference operator*() const { return (*p)->data; }
        pointer operator->() const { return &(*p)->data; }
        iterator& operator++() { ++p; return *this; }
        iterator operator++(int) { auto t=*this; ++p; return t; }
        iterator& operator--() { --p; return *this; }
        bool operator==(const iterator& o) const { return p==o.p; }
        bool operator!=(const iterator& o) const { return p!=o.p; }
    };
    struct const_iterator {
        Node*const* p;
        using value_type = const pair<const Key, T>;
        using difference_type = ptrdiff_t;
        using pointer = const value_type*;
        using reference = const value_type&;
        using iterator_category = bidirectional_iterator_tag;
        const_iterator(Node*const* x = nullptr) : p(x) {}
        const_iterator(iterator i) : p(i.p) {}
        reference operator*() const { return (*p)->data; }
        pointer operator->() const { return &(*p)->data; }
        const_iterator& operator++() { ++p; return *this; }
        const_iterator operator++(int) { auto t=*this; ++p; return t; }
        bool operator==(const const_iterator& o) const { return p==o.p; }
        bool operator!=(const const_iterator& o) const { return p!=o.p; }
    };
    using reverse_iterator = std::reverse_iterator<iterator>;

    map() : arr_(nullptr), sz_(0), cap_(0), comp_() {}
    explicit map(const Compare& c, const Allocator& = Allocator()) : arr_(nullptr), sz_(0), cap_(0), comp_(c) {}
    explicit map(const Allocator&) : arr_(nullptr), sz_(0), cap_(0), comp_() {}
    map(const map& o) : arr_(nullptr), sz_(0), cap_(0), comp_(o.comp_) {
        for (size_type i = 0; i < o.sz_; i++) insert(o.arr_[i]->data);
    }
    map(map&& o) noexcept : arr_(o.arr_), sz_(o.sz_), cap_(o.cap_), comp_(o.comp_) {
        o.arr_=nullptr; o.sz_=0; o.cap_=0;
    }
    map& operator=(const map& o) { if(this!=&o){clear();for(size_type i=0;i<o.sz_;i++)insert(o.arr_[i]->data);} return *this; }
    map& operator=(map&& o) noexcept { if(this!=&o){clear();arr_=o.arr_;sz_=o.sz_;cap_=o.cap_;o.arr_=nullptr;o.sz_=0;o.cap_=0;} return *this; }
    ~map() { clear(); if(arr_) ::operator delete(arr_); }

    T& operator[](const Key& k) {
        size_type p = fpos(k); if (p<sz_) return arr_[p]->data.second;
        if (sz_>=cap_) grow();
        size_type ip = ipos(k); shift_right(ip);
        arr_[ip] = static_cast<Node*>(::operator new(sizeof(Node)));
        ::new(arr_[ip]) Node(piecewise_construct, forward_as_tuple(k), forward_as_tuple());
        sz_++; return arr_[ip]->data.second;
    }
    T& operator[](Key&& k) {
        size_type p = fpos(k); if (p<sz_) return arr_[p]->data.second;
        if (sz_>=cap_) grow();
        size_type ip = ipos(k); shift_right(ip);
        arr_[ip] = static_cast<Node*>(::operator new(sizeof(Node)));
        ::new(arr_[ip]) Node(piecewise_construct, forward_as_tuple(static_cast<Key&&>(k)), forward_as_tuple());
        sz_++; return arr_[ip]->data.second;
    }

    iterator begin() { return {arr_}; }
    iterator end() { return {arr_+sz_}; }
    const_iterator begin() const { return {arr_}; }
    const_iterator end() const { return {arr_+sz_}; }
    const_iterator cbegin() const { return begin(); }
    const_iterator cend() const { return end(); }
    reverse_iterator rbegin() { return reverse_iterator(end()); }
    reverse_iterator rend() { return reverse_iterator(begin()); }

    size_type size() const { return sz_; }
    bool empty() const { return sz_==0; }

    pair<iterator,bool> insert(const value_type& v) {
        size_type p=fpos(v.first); if(p<sz_) return {iterator(arr_+p),false};
        if(sz_>=cap_) grow();
        size_type ip=ipos(v.first); shift_right(ip);
        arr_[ip]=make_node(v); sz_++;
        return {iterator(arr_+ip),true};
    }
    template<class... Args>
    pair<iterator,bool> emplace(Args&&... args) {
        Node* n=static_cast<Node*>(::operator new(sizeof(Node)));
        ::new(n) Node(static_cast<Args&&>(args)...);
        size_type p=fpos(n->data.first);
        if(p<sz_){free_node(n);return{iterator(arr_+p),false};}
        if(sz_>=cap_) grow();
        size_type ip=ipos(n->data.first); shift_right(ip);
        arr_[ip]=n; sz_++;
        return {iterator(arr_+ip),true};
    }

    iterator find(const Key& k) { size_type p=fpos(k); return p<sz_?iterator(arr_+p):end(); }
    const_iterator find(const Key& k) const { size_type p=fpos(k); return p<sz_?const_iterator(arr_+p):end(); }
    size_type count(const Key& k) const { return fpos(k)<sz_?1:0; }
    bool contains(const Key& k) const { return fpos(k)<sz_; }

    size_type erase(const Key& k) {
        size_type p=fpos(k); if(p>=sz_) return 0;
        free_node(arr_[p]);
        for(size_type i=p;i<sz_-1;i++) arr_[i]=arr_[i+1];
        sz_--; return 1;
    }
    iterator erase(iterator it) {
        size_type p=it.p-arr_; if(p>=sz_) return end();
        free_node(arr_[p]);
        for(size_type i=p;i<sz_-1;i++) arr_[i]=arr_[i+1];
        sz_--; return iterator(arr_+p);
    }
    iterator erase(const_iterator it) {
        size_type p=it.p-arr_; if(p>=sz_) return end();
        free_node(arr_[p]);
        for(size_type i=p;i<sz_-1;i++) arr_[i]=arr_[i+1];
        sz_--; return iterator(arr_+p);
    }
    void clear() { for(size_type i=0;i<sz_;i++) free_node(arr_[i]); sz_=0; }

    iterator lower_bound(const Key& k) { return iterator(arr_+ipos(k)); }
    const_iterator lower_bound(const Key& k) const { return const_iterator(arr_+ipos(k)); }
    iterator upper_bound(const Key& k) {
        size_type i=ipos(k); while(i<sz_&&!comp_(k,arr_[i]->data.first))i++; return iterator(arr_+i);
    }
    pair<iterator,iterator> equal_range(const Key& k) { return {lower_bound(k),upper_bound(k)}; }

    allocator_type get_allocator() const { return Allocator(); }
    key_compare key_comp() const { return comp_; }
};

template<class K, class T, class C = less<K>, class A = allocator<pair<const K,T>>>
using multimap = map<K,T,C,A>;

} // namespace std
#endif
