#ifndef _BAT_VECTOR
#define _BAT_VECTOR

#include <cstddef>
#include <cstdlib>
#include <memory>
#include <cstring>
#include <type_traits>
#include <utility>
#include <new>
#include <initializer_list>
#include <iterator>
#include <memory>

// operator new/delete provided by the OS
extern void* operator new(unsigned long);
extern void  operator delete(void*) noexcept;
extern void  operator delete(void*, unsigned long) noexcept;

namespace std {

template<class T, class Allocator = allocator<T>>
class vector {
public:
    using value_type      = T;
    using allocator_type  = Allocator;
    using size_type       = size_t;
    using difference_type = ptrdiff_t;
    using reference       = T&;
    using const_reference = const T&;
    using pointer         = T*;
    using const_pointer   = const T*;
    using iterator        = T*;
    using const_iterator  = const T*;
    using reverse_iterator       = std::reverse_iterator<iterator>;
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;

private:
    T*     _data;
    size_t _size;
    size_t _cap;

    void _destroy_all() {
        if constexpr (!is_trivially_destructible_v<T>) {
            for (size_t i = 0; i < _size; ++i)
                _data[i].~T();
        }
    }

    void _free() {
        if (_data) {
            _destroy_all();
            ::operator delete(static_cast<void*>(_data));
            _data = nullptr;
        }
    }

    void _grow(size_t new_cap) {
        if (new_cap <= _cap) return;
        size_t alloc = new_cap;
        if (alloc < _cap * 2 && _cap > 0) alloc = _cap * 2;
        if (alloc < 8) alloc = 8;
        T* buf = static_cast<T*>(::operator new(alloc * sizeof(T)));
        if (_data && _size > 0) {
            if constexpr (is_trivially_copyable_v<T>) {
                memcpy(buf, _data, _size * sizeof(T));
            } else {
                for (size_t i = 0; i < _size; ++i)
                    ::new(&buf[i]) T(std::move(_data[i]));
                _destroy_all();
            }
            ::operator delete(static_cast<void*>(_data));
        }
        _data = buf;
        _cap = alloc;
    }

public:
    // Constructors
    vector() noexcept : _data(nullptr), _size(0), _cap(0) {}

    explicit vector(size_t count) : _data(nullptr), _size(0), _cap(0) {
        resize(count);
    }

    vector(size_t count, const T& value) : _data(nullptr), _size(0), _cap(0) {
        reserve(count);
        for (size_t i = 0; i < count; ++i)
            push_back(value);
    }

    template<class InputIt, class = decltype(*std::declval<InputIt>())>
    vector(InputIt first, InputIt last) : _data(nullptr), _size(0), _cap(0) {
        for (; first != last; ++first)
            push_back(*first);
    }

    vector(initializer_list<T> init) : _data(nullptr), _size(0), _cap(0) {
        reserve(init.size());
        for (auto& v : init) push_back(v);
    }

    vector(const vector& o) : _data(nullptr), _size(0), _cap(0) {
        reserve(o._size);
        for (size_t i = 0; i < o._size; ++i)
            push_back(o._data[i]);
    }

    vector(vector&& o) noexcept : _data(o._data), _size(o._size), _cap(o._cap) {
        o._data = nullptr;
        o._size = 0;
        o._cap = 0;
    }

    ~vector() { _free(); }

    // Assignment
    vector& operator=(const vector& o) {
        if (this != &o) {
            clear();
            reserve(o._size);
            for (size_t i = 0; i < o._size; ++i)
                push_back(o._data[i]);
        }
        return *this;
    }

    vector& operator=(vector&& o) noexcept {
        if (this != &o) {
            _free();
            _data = o._data;
            _size = o._size;
            _cap = o._cap;
            o._data = nullptr;
            o._size = 0;
            o._cap = 0;
        }
        return *this;
    }

    vector& operator=(initializer_list<T> init) {
        clear();
        reserve(init.size());
        for (auto& v : init) push_back(v);
        return *this;
    }

    void assign(size_t count, const T& value) {
        clear();
        reserve(count);
        for (size_t i = 0; i < count; ++i) push_back(value);
    }

    template<class InputIt>
    void assign(InputIt first, InputIt last) {
        clear();
        for (; first != last; ++first) push_back(*first);
    }

    void assign(initializer_list<T> init) {
        clear();
        reserve(init.size());
        for (auto& v : init) push_back(v);
    }

    // Element access
    T& operator[](size_t i) { return _data[i]; }
    const T& operator[](size_t i) const { return _data[i]; }
    T& at(size_t i) { if (i >= _size) abort(); return _data[i]; }
    const T& at(size_t i) const { if (i >= _size) abort(); return _data[i]; }
    T& front() { return _data[0]; }
    const T& front() const { return _data[0]; }
    T& back() { return _data[_size - 1]; }
    const T& back() const { return _data[_size - 1]; }
    T* data() noexcept { return _data; }
    const T* data() const noexcept { return _data; }

    // Iterators
    iterator       begin()        noexcept { return _data; }
    const_iterator begin()  const noexcept { return _data; }
    const_iterator cbegin() const noexcept { return _data; }
    iterator       end()          noexcept { return _data + _size; }
    const_iterator end()    const noexcept { return _data + _size; }
    const_iterator cend()   const noexcept { return _data + _size; }
    reverse_iterator       rbegin()        noexcept { return reverse_iterator(end()); }
    const_reverse_iterator rbegin()  const noexcept { return const_reverse_iterator(end()); }
    reverse_iterator       rend()          noexcept { return reverse_iterator(begin()); }
    const_reverse_iterator rend()    const noexcept { return const_reverse_iterator(begin()); }

    // Capacity
    bool   empty()    const noexcept { return _size == 0; }
    size_t size()     const noexcept { return _size; }
    size_t capacity() const noexcept { return _cap; }
    size_t max_size() const noexcept { return static_cast<size_t>(-1) / sizeof(T); }

    void reserve(size_t new_cap) { _grow(new_cap); }

    void shrink_to_fit() {} // no-op

    // Modifiers
    void clear() noexcept {
        _destroy_all();
        _size = 0;
    }

    void push_back(const T& v) {
        if (_size >= _cap) _grow(_size + 1);
        ::new(&_data[_size]) T(v);
        ++_size;
    }

    void push_back(T&& v) {
        if (_size >= _cap) _grow(_size + 1);
        ::new(&_data[_size]) T(std::move(v));
        ++_size;
    }

    template<class... Args>
    T& emplace_back(Args&&... args) {
        if (_size >= _cap) _grow(_size + 1);
        ::new(&_data[_size]) T(std::forward<Args>(args)...);
        return _data[_size++];
    }

    void pop_back() {
        if (_size > 0) {
            --_size;
            if constexpr (!is_trivially_destructible_v<T>)
                _data[_size].~T();
        }
    }

    void resize(size_t count) {
        if (count > _cap) _grow(count);
        if (count > _size) {
            for (size_t i = _size; i < count; ++i)
                ::new(&_data[i]) T();
        } else {
            if constexpr (!is_trivially_destructible_v<T>) {
                for (size_t i = count; i < _size; ++i)
                    _data[i].~T();
            }
        }
        _size = count;
    }

    void resize(size_t count, const T& value) {
        if (count > _cap) _grow(count);
        if (count > _size) {
            for (size_t i = _size; i < count; ++i)
                ::new(&_data[i]) T(value);
        } else {
            if constexpr (!is_trivially_destructible_v<T>) {
                for (size_t i = count; i < _size; ++i)
                    _data[i].~T();
            }
        }
        _size = count;
    }

    iterator insert(const_iterator pos, const T& value) {
        size_t idx = pos - _data;
        if (_size >= _cap) _grow(_size + 1);
        // shift elements right
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx + 1, _data + idx, (_size - idx) * sizeof(T));
        } else {
            for (size_t i = _size; i > idx; --i) {
                ::new(&_data[i]) T(std::move(_data[i-1]));
                _data[i-1].~T();
            }
        }
        ::new(&_data[idx]) T(value);
        ++_size;
        return _data + idx;
    }

    iterator insert(const_iterator pos, T&& value) {
        size_t idx = pos - _data;
        if (_size >= _cap) _grow(_size + 1);
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx + 1, _data + idx, (_size - idx) * sizeof(T));
        } else {
            for (size_t i = _size; i > idx; --i) {
                ::new(&_data[i]) T(std::move(_data[i-1]));
                _data[i-1].~T();
            }
        }
        ::new(&_data[idx]) T(std::move(value));
        ++_size;
        return _data + idx;
    }

    iterator insert(const_iterator pos, size_t count, const T& value) {
        size_t idx = pos - _data;
        if (_size + count > _cap) _grow(_size + count);
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx + count, _data + idx, (_size - idx) * sizeof(T));
        } else {
            for (size_t i = _size + count - 1; i >= idx + count; --i) {
                ::new(&_data[i]) T(std::move(_data[i - count]));
                _data[i - count].~T();
            }
        }
        for (size_t i = 0; i < count; ++i)
            ::new(&_data[idx + i]) T(value);
        _size += count;
        return _data + idx;
    }

    template<class InputIt>
    iterator insert(const_iterator pos, InputIt first, InputIt last) {
        size_t idx = pos - _data;
        // Collect into temp buffer first
        vector<T> tmp(first, last);
        size_t count = tmp.size();
        if (count == 0) return _data + idx;
        if (_size + count > _cap) _grow(_size + count);
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx + count, _data + idx, (_size - idx) * sizeof(T));
        } else {
            for (size_t i = _size + count - 1; i >= idx + count; --i) {
                ::new(&_data[i]) T(std::move(_data[i - count]));
                _data[i - count].~T();
            }
        }
        for (size_t i = 0; i < count; ++i)
            ::new(&_data[idx + i]) T(std::move(tmp[i]));
        _size += count;
        return _data + idx;
    }

    iterator erase(const_iterator pos) {
        size_t idx = pos - _data;
        if constexpr (!is_trivially_destructible_v<T>)
            _data[idx].~T();
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx, _data + idx + 1, (_size - idx - 1) * sizeof(T));
        } else {
            for (size_t i = idx; i + 1 < _size; ++i) {
                ::new(&_data[i]) T(std::move(_data[i+1]));
                _data[i+1].~T();
            }
        }
        --_size;
        return _data + idx;
    }

    iterator erase(const_iterator first, const_iterator last) {
        size_t idx = first - _data;
        size_t count = last - first;
        if (count == 0) return _data + idx;
        if constexpr (!is_trivially_destructible_v<T>) {
            for (size_t i = idx; i < idx + count; ++i)
                _data[i].~T();
        }
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx, _data + idx + count, (_size - idx - count) * sizeof(T));
        } else {
            for (size_t i = idx; i + count < _size; ++i) {
                ::new(&_data[i]) T(std::move(_data[i + count]));
                _data[i + count].~T();
            }
        }
        _size -= count;
        return _data + idx;
    }

    template<class... Args>
    iterator emplace(const_iterator pos, Args&&... args) {
        size_t idx = pos - _data;
        if (_size >= _cap) _grow(_size + 1);
        if constexpr (is_trivially_copyable_v<T>) {
            memmove(_data + idx + 1, _data + idx, (_size - idx) * sizeof(T));
        } else {
            for (size_t i = _size; i > idx; --i) {
                ::new(&_data[i]) T(std::move(_data[i-1]));
                _data[i-1].~T();
            }
        }
        ::new(&_data[idx]) T(std::forward<Args>(args)...);
        ++_size;
        return _data + idx;
    }

    void swap(vector& o) noexcept {
        std::swap(_data, o._data);
        std::swap(_size, o._size);
        std::swap(_cap, o._cap);
    }

    allocator_type get_allocator() const noexcept { return Allocator(); }
};

template<class T, class A>
bool operator==(const vector<T,A>& a, const vector<T,A>& b) {
    if (a.size() != b.size()) return false;
    for (size_t i = 0; i < a.size(); ++i)
        if (!(a[i] == b[i])) return false;
    return true;
}
template<class T, class A>
bool operator!=(const vector<T,A>& a, const vector<T,A>& b) { return !(a == b); }

} // namespace std

#endif
