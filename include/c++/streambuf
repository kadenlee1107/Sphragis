#ifndef _BAT_STREAMBUF
#define _BAT_STREAMBUF

#include <iosfwd>
#include <cstddef>

namespace std {

template<class CharT, class Traits>
class basic_streambuf {
public:
    using char_type = CharT;
    using int_type = int;

    virtual ~basic_streambuf() = default;

    virtual streamsize xsputn(const char_type* s, streamsize n) { (void)s; return n; }
    virtual int_type overflow(int_type c = -1) { return c; }
    virtual streamsize xsgetn(char_type* s, streamsize n) { (void)s; (void)n; return 0; }
    virtual int_type underflow() { return -1; }
    virtual int sync() { return 0; }

    streamsize sputn(const char_type* s, streamsize n) { return xsputn(s, n); }
    int_type sputc(char_type c) { return overflow(c); }

protected:
    basic_streambuf() = default;
};

using streambuf = basic_streambuf<char>;

} // namespace std

#endif
