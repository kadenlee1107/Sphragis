#ifndef _BAT_CONCEPTS
#define _BAT_CONCEPTS

#include <type_traits>

namespace std {

// Core language concepts (C++20)
template<class T, class U>
concept same_as = is_same_v<T, U> && is_same_v<U, T>;

template<class Derived, class Base>
concept derived_from = is_base_of_v<Base, Derived> &&
    is_convertible_v<const volatile Derived*, const volatile Base*>;

template<class From, class To>
concept convertible_to = is_convertible_v<From, To>;

template<class T>
concept integral = is_integral_v<T>;

template<class T>
concept signed_integral = integral<T> && is_signed_v<T>;

template<class T>
concept unsigned_integral = integral<T> && !is_signed_v<T>;

template<class T>
concept floating_point = is_floating_point_v<T>;

template<class T>
concept destructible = is_nothrow_destructible_v<T>;

template<class T, class... Args>
concept constructible_from = destructible<T> && is_constructible_v<T, Args...>;

template<class T>
concept default_initializable = constructible_from<T>;

template<class T>
concept move_constructible = constructible_from<T, T>;

template<class T>
concept copy_constructible = move_constructible<T> && constructible_from<T, T&>
    && constructible_from<T, const T&> && constructible_from<T, const T>;

// Comparison concepts
template<class T>
concept equality_comparable = requires(const T& a, const T& b) {
    { a == b } -> convertible_to<bool>;
    { a != b } -> convertible_to<bool>;
};

template<class T, class U>
concept equality_comparable_with = requires(const T& t, const U& u) {
    { t == u } -> convertible_to<bool>;
    { t != u } -> convertible_to<bool>;
    { u == t } -> convertible_to<bool>;
    { u != t } -> convertible_to<bool>;
};

// Invocable
template<class F, class... Args>
concept invocable = requires(F&& f, Args&&... args) {
    static_cast<F&&>(f)(static_cast<Args&&>(args)...);
};

// Iterator concepts
template<class T>
concept input_iterator = requires(T it) {
    { *it };
    { ++it } -> same_as<T&>;
};

template<class T>
concept forward_iterator = input_iterator<T> && default_initializable<T>;

template<class T>
concept bidirectional_iterator = forward_iterator<T> && requires(T it) {
    { --it } -> same_as<T&>;
};

template<class T>
concept random_access_iterator = bidirectional_iterator<T> && requires(T it, int n) {
    { it + n } -> same_as<T>;
    { it - n } -> same_as<T>;
};

template<class T>
concept contiguous_iterator = random_access_iterator<T>;

// Range concepts (simplified — avoid needing <iterator>)
template<class T>
concept range = requires(T& t) {
    t.begin();
    t.end();
};

// Comparison concepts
template<class T, class U>
concept totally_ordered_with = requires(const T& t, const U& u) {
    { t < u } -> convertible_to<bool>;
    { t > u } -> convertible_to<bool>;
    { t <= u } -> convertible_to<bool>;
    { t >= u } -> convertible_to<bool>;
    { u < t } -> convertible_to<bool>;
    { u > t } -> convertible_to<bool>;
};

template<class T, class U = T>
concept three_way_comparable_with = requires(const T& t, const U& u) {
    { t < u } -> convertible_to<bool>;
    { t > u } -> convertible_to<bool>;
    { t == u } -> convertible_to<bool>;
};

} // namespace std

#endif
