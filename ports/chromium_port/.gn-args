# Bat_OS — pinned GN arguments for content_shell ARM64 build
# See CHROMIUM_PORT_PLAN.md Phase 1 for the rationale on each flag.

# === Target ===
target_os                      = "linux"
target_cpu                     = "arm64"

# === Optimization ===
is_official_build              = true
is_debug                       = false
symbol_level                   = 0
blink_symbol_level             = 0
v8_symbol_level                = 0

# === Linking ===
is_component_build             = false
treat_warnings_as_errors       = false

# === Use Chromium's bundled toolchain + sysroot ===
use_sysroot                    = true
use_lld                        = true
clang_use_chrome_plugins       = false

# === Disable everything we don't need ===
# NOTE: gn parses every BUILD.gn file in the tree (assertions fire at parse time)
# even when we --root-target=content_shell. Many chrome/* targets assert features
# we don't actually need to BUILD — but we need them ENABLED for parsing to succeed.
# The actual content_shell binary won't include any of this code.
# enable_nacl removed in M132+ (NaCl deprecated)
enable_widevine                = true
enable_pdf                     = true
enable_print_preview           = true
enable_remoting                = false
enable_extensions              = true
enable_extensions_core         = true
enable_plugins                 = true
enable_hangout_services_extension = false
proprietary_codecs             = false
ffmpeg_branding                = "Chromium"
safe_browsing_mode             = 1   # 0=disabled, 1=full, 2=android-only
chrome_pgo_phase               = 0

# === No host integrations (we don't have these on Bat_OS) ===
use_alsa                       = false
use_pulseaudio                 = false
use_cups                       = false
use_dbus                       = false
use_kerberos                   = false
use_gnome_keyring              = false
use_glib                       = false
use_gio                        = false
use_udev                       = false
use_gtk                        = false   # we don't have GTK, no Linux UI

# === Ozone (display backend abstraction) ===
use_ozone                      = true
ozone_auto_platforms           = false
ozone_platform_headless        = true
ozone_platform                 = "headless"

# Phase 5 will switch to: ozone_platform = "batos"
# and add: ozone_extra_path = "//ui/ozone/platform/batos/ozone_extra.gni"

# === Headless / startup ===
v8_use_external_startup_data    = true
