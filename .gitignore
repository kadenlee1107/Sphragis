# Bat_OS .gitignore

# Cargo build artifacts — reproducible via `cargo build`.
/target

# Vendored Chromium source tree (~1.9 GB, contains a pack file over
# GitHub's 100 MB limit). Re-clone upstream if you need it.
/ports/chromium

# Docker volumes / build artifacts from the Chromium container work.
/chromium-build
.DS_Store

# Compressed logs from past sessions (regenerable).
*.log

# Claude Code / harness local state (not project state).
/.claude
/.claude-flow
/.mcp.json
# Harness state also shows up inside vendored submodules.
**/.claude-flow/
**/__pycache__/

# Bring-up research data now tracked (private repo, Kaden's personal tool).
# Previously ignored: /captures, firmware/, macos_dump/.
# Big files in macos_dump/ (>100 MB) are split into .partNN chunks;
# see macos_dump/README.md for reassembly.

# Split-file parts — don't track source files if they're already split.
macos_dump/kernelcache.mac16j.bin
macos_dump/SystemKernelExtensions.kc
